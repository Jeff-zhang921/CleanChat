{
  "name": "express",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "jest --config jest.config.js",
    "lint": "eslint . ",
    "build": "tsc --build",
    "start": "node ./dist/index.js",
    "dev": "nodemon --exec \"ts-node --files\" index.ts",
    "db:start": "prisma dev start default --detach",
    "db:stop": "prisma dev stop default",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "ts-node --files src/seed.ts",
    "db:init": "npm run db:start && npm run db:generate && npm run db:push && npm run db:seed"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx$": "ts-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "js",
      "json",
      "node"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "prisma": {
    "seed": "ts-node src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "nodemailer": "^6.10.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@jest/globals": "^30.2.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.13",
    "@types/nodemailer": "^6.4.21",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.2",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "jiti": "^2.6.1",
    "nodemon": "^3.1.10",
    "prisma": "^6.19.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
